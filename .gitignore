# Xmake build files
.xmake/
build/
.cache/

# CMake build files
*.cmake

# Compiled files
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# Allow FFmpeg prebuilt binaries
!third_party/ffmpeg/bin/*.dll
!third_party/ffmpeg/lib/*.lib
!third_party/ffmpeg-macos/lib/*.dylib

# Allow yt-dlp prebuilt binaries
!third_party/yt-dlp/yt-dlp_macos
!third_party/yt-dlp/yt-dlp.exe

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
*.dSYM

# Log files
*.log

# Temporary files
*.tmp
*.temp

# Binary output
*.out

# Packaging output
dist/
*.dmg
